{% if stats %}
<div class="stat-block">
  {% for name, value in stats %}
  {% set mod = ((value - 10) / 2) | round(0, "floor") %}
  <div class="stat">
    <span class="stat-name">{{ name }} {{ value }}</span>
    <span class="stat-mod">{% if mod >= 0 %}+{% endif %}{{ mod }}</span>
    <roll-dice class="stat-roll">1d20{% if mod >= 0 %}+{% endif %}{{ mod }}</roll-dice>
  </div>
  {% endfor %}
</div>
{% endif %}
